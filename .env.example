# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/db/database.db

# File uploads
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE=10485760

# OCR
OCR_PROVIDER=tesseract
TESSERACT_CMD=tesseract
TESSERACT_LANG=spa
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_MAX_IMAGE_SIZE_MB=4

# Observability — Langfuse (optional — leave empty to disable tracing)
# Get these from Langfuse UI → Settings → API Keys (http://localhost:3000)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# App
DEBUG=false
SECRET_KEY=change-this-secret-key-in-production

# CORS — comma-separated list of allowed origins
# Local dev defaults are set in config.py; override here for staging/prod.
# Example: CORS_ALLOWED_ORIGINS=https://exam.example.com,http://localhost:3000
# CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE
# CORS_ALLOWED_HEADERS=Authorization,Content-Type

# OpenAI (uncomment and fill in your key)
# OPENAI_API_KEY=sk-your-key-here
